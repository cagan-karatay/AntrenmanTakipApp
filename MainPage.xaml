                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBolgeTapped" />
                </Border.GestureRecognizers>

                <HorizontalStackLayout Padding="20" Spacing="20" VerticalOptions="Center">

                    <Image Source="legs.png" 
                       HeightRequest="70" 
                       WidthRequest="70" />

                    <Label Text="Legs"
                       TextColor="White"
                       FontSize="22"
                       FontAttributes="Bold"
                       VerticalOptions="Center" />

                </HorizontalStackLayout>
            </Border>

            <Border ClassId="Shoulders"
