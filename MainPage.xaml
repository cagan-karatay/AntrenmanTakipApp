<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AntrenmanTakipApp.MainPage"
             BackgroundColor="#282b30">

    <ScrollView>
        <VerticalStackLayout
            Padding="30, 0, 30, 30"
            Spacing="10"
            VerticalOptions="Start">

            <Label
                Text="Antreman Ekleme"
                TextColor="White"
                Style="{StaticResource SubHeadline}"
                SemanticProperties.HeadingLevel="Level2"
                SemanticProperties.Description="Welcome to dot net Multi platform App U I" />

            <Border ClassId="Chest"
                BackgroundColor="#36393e"
                StrokeThickness="0"
                HeightRequest="80">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15" />
                </Border.StrokeShape>

                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBolgeTapped" />
                </Border.GestureRecognizers>

                <HorizontalStackLayout Padding="15" Spacing="15" VerticalOptions="Center">

                    <Image Source="chest.png" 
                       HeightRequest="80" 
                       WidthRequest="80" />

                    <Label Text="Chest"
                       TextColor="White"
                       FontSize="22"
                       FontAttributes="Bold"
                       VerticalOptions="Center" />

                </HorizontalStackLayout>
            </Border>

            <Border ClassId="Back"
                BackgroundColor="#36393e"
                StrokeThickness="0"
                HeightRequest="80">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15" />
