                    <Image Source="back.png" 
                       HeightRequest="80" 
                       WidthRequest="80" />

                    <Label Text="Back"
                       TextColor="White"
                       FontSize="22"
                       FontAttributes="Bold"
                       VerticalOptions="Center" />

                </HorizontalStackLayout>
            </Border>

