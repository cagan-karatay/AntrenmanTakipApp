<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AntrenmanTakipApp.AnaSayfaView"
             BackgroundColor="Transparent">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20">

            <VerticalStackLayout x:Name="AktifBolumu" IsVisible="False" Spacing="10">
                <Label Text="Aktif" TextColor="#22ff00" FontAttributes="Bold" FontSize="20" Margin="10,0,0,0">
                    <Label.Shadow>
                        <Shadow Brush="#22ff00" Opacity="0.8" Radius="15" />
                    </Label.Shadow>
                </Label>

                <Border Stroke="#22ff00" StrokeThickness="2" BackgroundColor="#36393e" Padding="15">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#22ff00" Opacity="0.4" Radius="15" />
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="15">

                        <Border BackgroundColor="#282b30" StrokeThickness="0" Padding="15">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="*, Auto">
                                <Label x:Name="AktifAdLabel" TextColor="White" FontAttributes="Bold" FontSize="18" VerticalOptions="Center" />
                                <Label x:Name="AktifAgirliklarLabel" Grid.Column="1" TextColor="#94a3b8" FontSize="16" VerticalOptions="Center" />
                            </Grid>
                        </Border>

                        <Button Style="{x:Null}" Text="Devam Et" Clicked="OnAktifDevamEtClicked" 
                                BackgroundColor="Transparent" BorderColor="#22ff00" BorderWidth="2" TextColor="#22ff00" FontAttributes="Bold" CornerRadius="10">
                            <Button.Shadow>
                                <Shadow Brush="#22ff00" Opacity="0.6" Radius="10"/>
                            </Button.Shadow>
                        </Button>

                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout x:Name="GecmisBolumu" IsVisible="False" Spacing="10" Margin="0,15,0,30">
                <Label Text="Bugünkü Hareketler" TextColor="#ffff00" FontAttributes="Bold" FontSize="18" Margin="10,0,0,0">
                    <Label.Shadow>
                        <Shadow Brush="#ffff00" Opacity="0.8" Radius="15" />
                    </Label.Shadow>
                </Label>

                <VerticalStackLayout x:Name="BugunkuHareketlerListesi" Spacing="15">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="#36393e" StrokeThickness="0" Padding="15">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="15" />
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="15">

                                    <Border BackgroundColor="#282b30" StrokeThickness="0" Padding="15">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="10" />
                                        </Border.StrokeShape>
                                        <Grid ColumnDefinitions="*, Auto">
                                            <Label Text="{Binding Ad}" TextColor="White" FontAttributes="Bold" FontSize="18" VerticalOptions="Center" />
                                            <Label Grid.Column="1" Text="{Binding AgirliklarString}" TextColor="#94a3b8" FontSize="16" VerticalOptions="Center" />
                                        </Grid>
                                    </Border>

                                    <Button Style="{x:Null}" Text="Devam Et" Clicked="OnListeDevamEtClicked" CommandParameter="{Binding Hareket}"
                                            BackgroundColor="Transparent" BorderColor="#22ff00" BorderWidth="2" TextColor="#22ff00" FontAttributes="Bold" CornerRadius="10">
                                        <Button.Shadow>
                                            <Shadow Brush="#22ff00" Opacity="0.3" Radius="10"/>
                                        </Button.Shadow>
                                    </Button>

                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </VerticalStackLayout>

            <Label x:Name="BosDurumLabel" Text="Spora başlama vakti! Bu günün ilk hareketini seç." 
                   TextColor="#94a3b8" HorizontalOptions="Center" VerticalOptions="Center" Margin="0,80,0,0" FontAttributes="Italic"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentView>