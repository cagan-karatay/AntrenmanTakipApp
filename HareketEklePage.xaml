<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AntrenmanTakipApp.HareketEklePage"
             BackgroundColor="#282b30"
             Title="Hareket Ekle">

    <VerticalStackLayout VerticalOptions="Start" Spacing="20" Padding="20" Margin="0,10,0,0">

        <Border BackgroundColor="#36393e" StrokeThickness="0" Padding="15">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="15" />
            </Border.StrokeShape>

            <VerticalStackLayout Spacing="15">
                <Label Text="HAREKET ADI" TextColor="#94a3b8" FontSize="12" FontAttributes="Bold" />

                <Entry x:Name="HareketAdiEntry" 
                       Placeholder="Örn: Bench Press..." 
                       TextColor="White" 
                       FontSize="18"
                       TextChanged="OnHareketTextChanged" />

                <Button Style="{x:Null}" 
                        Text="KAYDET" 
                        Clicked="OnKaydetClicked" 
                        BackgroundColor="#22ff00" 
                        TextColor="#1e1e1e" 
                        FontAttributes="Bold" 
                        CornerRadius="10" 
                        HeightRequest="50">
                    <Button.Shadow>
                        <Shadow Brush="#22ff00" Offset="0,0" Radius="10" Opacity="0.3" />
                    </Button.Shadow>
                </Button>
            </VerticalStackLayout>
        </Border>

        <Label Text="Hazır Hareketler" TextColor="#ff6a00" FontAttributes="Bold" FontSize="18" Margin="5,10,0,0">
            <Label.Shadow>
                <Shadow Brush="#ff6a00" Offset="0,0" Radius="10" Opacity="0.6" />
            </Label.Shadow>
        </Label>

        <CollectionView x:Name="HazirHareketlerListesi" 
                        SelectionMode="Single" 
                        SelectionChanged="OnHazirHareketSelected" 
                        HeightRequest="400">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border BackgroundColor="#36393e" StrokeThickness="0" Margin="0,0,0,8" Padding="15">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10" />
                        </Border.StrokeShape>
                        <Label Text="{Binding .}" TextColor="White" FontSize="16" FontAttributes="Bold" VerticalOptions="Center" />
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>
</ContentPage>