<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AntrenmanTakipApp.HareketlerPage"
             BackgroundColor="#282b30">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="+" Clicked="OnEkleClicked" />
    </ContentPage.ToolbarItems>

    <CollectionView x:Name="HareketlerListesi" Margin="30, 20, 30, 30">

        <CollectionView.ItemTemplate>
            <DataTemplate>

                <Border BackgroundColor="#36393e" StrokeThickness="0" HeightRequest="80" Margin="0, 0, 0, 10">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15" />
                    </Border.StrokeShape>

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnHareketTapped" />
                    </Border.GestureRecognizers>

                    <HorizontalStackLayout Padding="20" VerticalOptions="Center">
                        <Label Text="{Binding Ad}"
                               TextColor="White"
                               FontSize="22"
                               FontAttributes="Bold"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>

</ContentPage>